{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"color": {
			"palette": [
				{ "color": "#f5f2ea", "name": "Background", "slug": "bg" },
				{ "color": "#1a1a1a", "name": "Ink", "slug": "ink" },
				{ "color": "#6b6b6b", "name": "Muted", "slug": "muted" },
				{ "color": "#d64545", "name": "Accent", "slug": "accent" },
				{ "color": "#fbe8e8", "name": "Accent soft", "slug": "accent-soft" },
				{ "color": "#fdfbf5", "name": "Paper", "slug": "paper" },
				{ "color": "#2d6a4f", "name": "Positive", "slug": "positive" },
				{ "color": "#9b2226", "name": "Negative", "slug": "negative" },
				{ "color": "#b8860b", "name": "Mixed", "slug": "mixed" },
				{ "color": "#1a1816", "name": "Background night", "slug": "bg-night" },
				{ "color": "#ede8de", "name": "Ink night", "slug": "ink-night" },
				{ "color": "#8a8578", "name": "Muted night", "slug": "muted-night" },
				{ "color": "#ede8de", "name": "Line night", "slug": "line-night" },
				{ "color": "#f07878", "name": "Accent night", "slug": "accent-night" },
				{ "color": "#3a1f1f", "name": "Accent soft night", "slug": "accent-soft-night" },
				{ "color": "#7fb896", "name": "Positive night", "slug": "positive-night" },
				{ "color": "#e07a7f", "name": "Negative night", "slug": "negative-night" },
				{ "color": "#8a8578", "name": "Neutral night", "slug": "neutral-night" },
				{ "color": "#d4a84d", "name": "Mixed night", "slug": "mixed-night" },
				{ "color": "#221f1c", "name": "Paper night", "slug": "paper-night" }
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "Fraunces, Georgia, serif",
					"name": "Fraunces",
					"slug": "fraunces",
					"fontFace": [
						{
							"fontFamily": "Fraunces",
							"fontWeight": "400 800",
							"fontStyle": "normal",
							"src": [ "file:./assets/fonts/fraunces-latin-wght-normal.woff2" ]
						},
						{
							"fontFamily": "Fraunces",
							"fontWeight": "400 800",
							"fontStyle": "italic",
							"src": [ "file:./assets/fonts/fraunces-latin-wght-italic.woff2" ]
						}
					]
				},
				{
					"fontFamily": "\"JetBrains Mono\", monospace",
					"name": "JetBrains Mono",
					"slug": "jetbrains-mono",
					"fontFace": [
						{
							"fontFamily": "JetBrains Mono",
							"fontWeight": "400",
							"fontStyle": "normal",
							"src": [ "file:./assets/fonts/jetbrains-mono-latin-400-normal.woff2" ]
						},
						{
							"fontFamily": "JetBrains Mono",
							"fontWeight": "400",
							"fontStyle": "italic",
							"src": [ "file:./assets/fonts/jetbrains-mono-latin-400-italic.woff2" ]
						},
						{
							"fontFamily": "JetBrains Mono",
							"fontWeight": "500",
							"fontStyle": "normal",
							"src": [ "file:./assets/fonts/jetbrains-mono-latin-500-normal.woff2" ]
						},
						{
							"fontFamily": "JetBrains Mono",
							"fontWeight": "500",
							"fontStyle": "italic",
							"src": [ "file:./assets/fonts/jetbrains-mono-latin-500-italic.woff2" ]
						}
					]
				}
			]
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--fraunces)",
			"fontSize": "1rem",
			"lineHeight": "1.5"
		},
		"color": {
			"background": "var(--wp--preset--color--bg)",
			"text": "var(--wp--preset--color--ink)"
		},
		"elements": {
			"link": {
				"color": { "text": "var(--wp--preset--color--ink)" }
			},
			"h1": {
				"typography": {
					"fontSize": "clamp(2.25rem, 9vw, 3.5rem)",
					"fontWeight": "800",
					"lineHeight": "1.05",
					"letterSpacing": "-0.03em"
				},
				"spacing": {
					"margin": { "top": "0", "bottom": "1rem" }
				}
			},
			"h2": {
				"typography": {
					"fontSize": "1.375rem",
					"fontWeight": "600",
					"lineHeight": "1.2",
					"letterSpacing": "-0.01em"
				},
				"spacing": {
					"margin": { "top": "2.5rem", "bottom": "0.75rem" }
				}
			},
			"h3": {
				"typography": {
					"fontSize": "1.125rem",
					"fontWeight": "600",
					"lineHeight": "1.25"
				}
			},
			"h4": {
				"typography": {
					"fontWeight": "600"
				}
			},
			"h5": {
				"typography": {
					"fontWeight": "600"
				}
			},
			"h6": {
				"typography": {
					"fontWeight": "600"
				}
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	]
}

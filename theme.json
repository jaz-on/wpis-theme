{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"color": {
			"palette": [
				{ "color": "#f5f2ea", "name": "Background", "slug": "bg" },
				{ "color": "#1a1a1a", "name": "Ink", "slug": "ink" },
				{ "color": "#6b6b6b", "name": "Muted", "slug": "muted" },
				{ "color": "#d64545", "name": "Accent", "slug": "accent" },
				{ "color": "#fbe8e8", "name": "Accent soft", "slug": "accent-soft" },
				{ "color": "#fdfbf5", "name": "Paper", "slug": "paper" },
				{ "color": "#2d6a4f", "name": "Positive", "slug": "positive" },
				{ "color": "#9b2226", "name": "Negative", "slug": "negative" },
				{ "color": "#b8860b", "name": "Mixed", "slug": "mixed" }
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "Fraunces, Georgia, serif",
					"name": "Fraunces",
					"slug": "fraunces",
					"fontFace": [
						{
							"fontFamily": "Fraunces",
							"fontWeight": "400 800",
							"fontStyle": "normal",
							"src": [ "file:./assets/fonts/fraunces-latin-wght-normal.woff2" ]
						},
						{
							"fontFamily": "Fraunces",
							"fontWeight": "400 800",
							"fontStyle": "italic",
							"src": [ "file:./assets/fonts/fraunces-latin-wght-italic.woff2" ]
						}
					]
				},
				{
					"fontFamily": "\"JetBrains Mono\", monospace",
					"name": "JetBrains Mono",
					"slug": "jetbrains-mono",
					"fontFace": [
						{
							"fontFamily": "JetBrains Mono",
							"fontWeight": "400",
							"fontStyle": "normal",
							"src": [ "file:./assets/fonts/jetbrains-mono-latin-400-normal.woff2" ]
						},
						{
							"fontFamily": "JetBrains Mono",
							"fontWeight": "400",
							"fontStyle": "italic",
							"src": [ "file:./assets/fonts/jetbrains-mono-latin-400-italic.woff2" ]
						},
						{
							"fontFamily": "JetBrains Mono",
							"fontWeight": "500",
							"fontStyle": "normal",
							"src": [ "file:./assets/fonts/jetbrains-mono-latin-500-normal.woff2" ]
						},
						{
							"fontFamily": "JetBrains Mono",
							"fontWeight": "500",
							"fontStyle": "italic",
							"src": [ "file:./assets/fonts/jetbrains-mono-latin-500-italic.woff2" ]
						}
					]
				}
			]
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--fraunces)"
		},
		"color": {
			"background": "var(--wp--preset--color--bg)",
			"text": "var(--wp--preset--color--ink)"
		},
		"elements": {
			"link": {
				"color": { "text": "var(--wp--preset--color--ink)" }
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	]
}

{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "720px",
			"wideSize": "1320px"
		},
		"color": {
			"palette": [
				{ "color": "#f5f2ea", "name": "Background", "slug": "bg" },
				{ "color": "#1a1a1a", "name": "Ink", "slug": "ink" },
				{ "color": "#6b6b6b", "name": "Muted", "slug": "muted" },
				{ "color": "#d64545", "name": "Accent", "slug": "accent" },
				{ "color": "#fbe8e8", "name": "Accent soft", "slug": "accent-soft" },
				{ "color": "#fdfbf5", "name": "Paper", "slug": "paper" },
				{ "color": "#2d6a4f", "name": "Positive", "slug": "positive" },
				{ "color": "#9b2226", "name": "Negative", "slug": "negative" },
				{ "color": "#b8860b", "name": "Mixed", "slug": "mixed" },
				{ "color": "#1a1816", "name": "Background night", "slug": "bg-night" },
				{ "color": "#ede8de", "name": "Ink night", "slug": "ink-night" },
				{ "color": "#8a8578", "name": "Muted night", "slug": "muted-night" },
				{ "color": "#ede8de", "name": "Line night", "slug": "line-night" },
				{ "color": "#f07878", "name": "Accent night", "slug": "accent-night" },
				{ "color": "#3a1f1f", "name": "Accent soft night", "slug": "accent-soft-night" },
				{ "color": "#7fb896", "name": "Positive night", "slug": "positive-night" },
				{ "color": "#e07a7f", "name": "Negative night", "slug": "negative-night" },
				{ "color": "#8a8578", "name": "Neutral night", "slug": "neutral-night" },
				{ "color": "#d4a84d", "name": "Mixed night", "slug": "mixed-night" },
				{ "color": "#221f1c", "name": "Paper night", "slug": "paper-night" }
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "Fraunces, Georgia, serif",
					"name": "Fraunces",
					"slug": "fraunces",
					"fontFace": [
						{
							"fontFamily": "Fraunces",
							"fontWeight": "400 800",
							"fontStyle": "normal",
							"src": [ "file:./assets/fonts/fraunces-latin-wght-normal.woff2" ]
						},
						{
							"fontFamily": "Fraunces",
							"fontWeight": "400 800",
							"fontStyle": "italic",
							"src": [ "file:./assets/fonts/fraunces-latin-wght-italic.woff2" ]
						}
					]
				},
				{
					"fontFamily": "\"JetBrains Mono\", monospace",
					"name": "JetBrains Mono",
					"slug": "jetbrains-mono",
					"fontFace": [
						{
							"fontFamily": "JetBrains Mono",
							"fontWeight": "400",
							"fontStyle": "normal",
							"src": [ "file:./assets/fonts/jetbrains-mono-latin-400-normal.woff2" ]
						},
						{
							"fontFamily": "JetBrains Mono",
							"fontWeight": "400",
							"fontStyle": "italic",
							"src": [ "file:./assets/fonts/jetbrains-mono-latin-400-italic.woff2" ]
						},
						{
							"fontFamily": "JetBrains Mono",
							"fontWeight": "500",
							"fontStyle": "normal",
							"src": [ "file:./assets/fonts/jetbrains-mono-latin-500-normal.woff2" ]
						},
						{
							"fontFamily": "JetBrains Mono",
							"fontWeight": "500",
							"fontStyle": "italic",
							"src": [ "file:./assets/fonts/jetbrains-mono-latin-500-italic.woff2" ]
						}
					]
				}
			]
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--fraunces)",
			"fontSize": "1rem",
			"lineHeight": "1.5"
		},
		"color": {
			"background": "var(--bg)",
			"text": "var(--ink)"
		},
		"elements": {
			"link": {
				"color": { "text": "var(--ink)" }
			},
			"h1": {
				"typography": {
					"fontSize": "clamp(2.25rem, 9vw, 3.5rem)",
					"fontWeight": "800",
					"lineHeight": "1.05",
					"letterSpacing": "-0.03em"
				},
				"spacing": {
					"margin": { "top": "0", "bottom": "1rem" }
				}
			},
			"h2": {
				"typography": {
					"fontSize": "1.375rem",
					"fontWeight": "600",
					"lineHeight": "1.2",
					"letterSpacing": "-0.01em"
				},
				"spacing": {
					"margin": { "top": "2.5rem", "bottom": "0.75rem" }
				}
			},
			"h3": {
				"typography": {
					"fontSize": "1.125rem",
					"fontWeight": "600",
					"lineHeight": "1.25"
				}
			},
			"h4": {
				"typography": {
					"fontWeight": "600"
				}
			},
			"h5": {
				"typography": {
					"fontWeight": "600"
				}
			},
			"h6": {
				"typography": {
					"fontWeight": "600"
				}
			},
			"mark": {
				"color": {
					"text": "var(--accent)",
					"background": "var(--accent-soft)"
				},
				"spacing": {
					"padding": {
						"top": "1px",
						"bottom": "1px",
						"left": "3px",
						"right": "3px"
					}
				}
			}
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontSize": "0.625rem",
					"fontFamily": "var(--wp--preset--font-family--jetbrains-mono)",
					"textTransform": "uppercase",
					"letterSpacing": "0.08em"
				},
				"spacing": {
					"blockGap": "0.875rem"
				}
			},
			"core/group": {
				"variations": {
					"wpis-hero": {
						"spacing": {
							"padding": {
								"top": "2.5rem",
								"bottom": "2rem",
								"left": "1.25rem",
								"right": "1.25rem"
							}
						},
						"border": {
							"bottom": {
								"color": "var(--line)",
								"width": "1px",
								"style": "solid"
							}
						}
					},
					"wpis-feed": {
						"spacing": {
							"padding": {
								"top": "1.75rem",
								"bottom": "1.75rem",
								"left": "1.25rem",
								"right": "1.25rem"
							}
						}
					},
					"wpis-prose": {
						"spacing": {
							"padding": {
								"top": "2.5rem",
								"bottom": "3.75rem",
								"left": "1.25rem",
								"right": "1.25rem"
							}
						}
					},
					"wpis-detail": {
						"spacing": {
							"padding": {
								"top": "1.75rem",
								"bottom": "3.75rem",
								"left": "1.25rem",
								"right": "1.25rem"
							}
						}
					},
					"wpis-submit": {
						"spacing": {
							"padding": {
								"top": "2rem",
								"bottom": "3.75rem",
								"left": "1.25rem",
								"right": "1.25rem"
							}
						}
					},
					"wpis-tax-hero": {
						"spacing": {
							"padding": {
								"top": "2rem",
								"bottom": "1.5rem",
								"left": "1.25rem",
								"right": "1.25rem"
							}
						},
						"border": {
							"bottom": {
								"color": "var(--line)",
								"width": "1px",
								"style": "solid"
							}
						}
					},
					"wpis-explore-hero": {
						"spacing": {
							"padding": {
								"top": "2.5rem",
								"bottom": "1.75rem",
								"left": "1.25rem",
								"right": "1.25rem"
							}
						},
						"border": {
							"bottom": {
								"color": "var(--line)",
								"width": "1px",
								"style": "solid"
							}
						}
					},
					"wpis-explore-section": {
						"spacing": {
							"padding": {
								"top": "2rem",
								"bottom": "2rem",
								"left": "1.25rem",
								"right": "1.25rem"
							}
						},
						"border": {
							"bottom": {
								"color": "var(--line)",
								"width": "1px",
								"style": "solid"
							}
						}
					},
					"wpis-search": {
						"spacing": {
							"padding": {
								"top": "1.5rem",
								"bottom": "1.5rem",
								"left": "1.25rem",
								"right": "1.25rem"
							}
						}
					},
					"wpis-how": {
						"spacing": {
							"padding": {
								"top": "2.5rem",
								"bottom": "3.75rem",
								"left": "1.25rem",
								"right": "1.25rem"
							}
						}
					},
					"wpis-profile": {
						"spacing": {
							"padding": {
								"top": "2rem",
								"bottom": "3.75rem",
								"left": "1.25rem",
								"right": "1.25rem"
							}
						}
					},
					"wpis-empty-state": {
						"spacing": {
							"padding": {
								"top": "3.75rem",
								"bottom": "3.75rem",
								"left": "1.25rem",
								"right": "1.25rem"
							}
						},
						"typography": {
							"textAlign": "center"
						}
					},
					"wpis-confirm": {
						"spacing": {
							"padding": {
								"top": "3rem",
								"bottom": "3rem",
								"left": "1.25rem",
								"right": "1.25rem"
							}
						},
						"typography": {
							"textAlign": "center"
						}
					}
				}
			},
			"core/paragraph": {
				"variations": {
					"wpis-eyebrow": {
						"typography": {
							"fontFamily": "var(--wp--preset--font-family--jetbrains-mono)",
							"fontSize": "0.625rem",
							"textTransform": "uppercase",
							"letterSpacing": "0.15em"
						},
						"color": {
							"text": "var(--muted)"
						}
					},
					"wpis-pull-quote": {
						"typography": {
							"fontSize": "1.5rem",
							"fontStyle": "italic",
							"lineHeight": "1.3"
						},
						"spacing": {
							"padding": {
								"top": "1.5rem",
								"bottom": "1.5rem"
							},
							"margin": {
								"top": "2rem",
								"bottom": "2rem"
							}
						},
						"border": {
							"top": {
								"color": "var(--line)",
								"width": "1px",
								"style": "solid"
							},
							"bottom": {
								"color": "var(--line)",
								"width": "1px",
								"style": "solid"
							}
						}
					}
				}
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" },
		{ "name": "quote-feed-card", "title": "Quote feed card", "area": "uncategorized" }
	]
}

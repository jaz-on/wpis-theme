{
	"name": "jaz-on/wpis-theme",
	"description": "WPIS block theme (development tools)",
	"license": "GPL-2.0-or-later",
	"require": {},
	"require-dev": {
		"squizlabs/php_codesniffer": "^3.13.4",
		"wp-coding-standards/wpcs": "^3.1",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"phpcs": "phpcs",
		"phpcbf": "phpcbf",
		"verify-markup": "php tools/verify-markup.php",
		"verify-markup-strict": "WPIS_VERIFY_MARKUP_STRICT=1 php tools/verify-markup.php"
	}
}
